# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/apps/web/.next/
/out/

# python backend
/apps/backend/.venv/
/apps/backend/.pytest_cache/
/apps/backend/**/__pycache__/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local agent state
.superpowers/

# local media exports
*.mp4
*.webm
*.mov
*.avi

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
